# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/abby-video-manager

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token_here

# TikTok API
TIKTOK_API_KEY=your_tiktok_api_key_here
TIKTOK_API_SECRET=your_tiktok_api_secret_here
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_REFRESH_TOKEN=your_tiktok_refresh_token_here

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_S3_BUCKET=your_s3_bucket_name
AWS_S3_REGION=us-east-1

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
